generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, vector]
}

// ─── Users ───────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  profileImage String? @map("profile_image")
  address   String?
  birthday  String?
  vehicles          Json?    // JSON array of saved vehicles
  notificationPrefs Json?    @map("notification_prefs") // push/email/sms preference toggles
  ref       String?  // signup source: "qr", "tiktok", "organic"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isPremium  Boolean  @default(false) @map("is_premium")
  isVendorPremium Boolean @default(false) @map("is_vendor_premium")
  isValetPremium  Boolean @default(false) @map("is_valet_premium")
  stripeCustomerId String? @unique @map("stripe_customer_id")

  hostProfile    HostProfile?
  valetProfile   ValetProfile?
  checkIns       CheckIn[]
  savedSpots     SavedSpot[]
  collections    SpotCollection[]
  pointTxns      PointTransaction[]
  achievements   UserAchievement[]
  preference     UserPreference?
  followers      Follow[]          @relation("following") // users who follow me
  following      Follow[]          @relation("follower")  // users I follow
  reviews        Review[]
  tipsGiven      Tip[]             @relation("tipFrom")
  accessPasses   AccessPass[]
  vendors        Vendor[]
  bookings       Booking[]
  complianceLogs ComplianceLog[]

  @@map("users")
}

model AccessPass {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  productId       String   @map("product_id")
  productType     String   @map("product_type")
  title           String
  subtitle        String?
  location        String
  priceLabel      String   @map("price_label")
  accessLabel     String   @map("access_label")
  orderNumber     String   @map("order_number")
  status          String   @default("confirmed")
  ticketUrl       String?  @map("ticket_url")
  source          String   @default("app")
  stripeSessionId String?  @unique @map("stripe_session_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, productType, productId])
  @@map("access_passes")
}

// ─── Venues ──────────────────────────────────────────
model Venue {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  address     String
  lat         Float
  lng         Float
  category    String   // "bar", "restaurant", "club", "park", "market"
  imageUrl    String?  @map("image_url")
  entryType   String   @default("free") @map("entry_type") // "free" or "paid"
  entryPrice  String?  @map("entry_price") // e.g. "$15", "$25–$50"
  ticketUrl   String?  @map("ticket_url") // external purchase link
  createdAt   DateTime @default(now()) @map("created_at")

  // PostGIS: geometry(Point, 4326) — populated from lat/lng
  // Managed via raw SQL; Prisma can't model geometry natively
  // Column: "location" geometry(Point, 4326)

  // pgvector: 384-dim embedding for AI similarity search
  // Column: "embedding" vector(384)

  crowdLevels CrowdLevel[]
  parking     ParkingSpot[]
  checkIns    CheckIn[]
  savedBy     SavedSpot[]
  reviews     Review[]

  @@map("venues")
}

// ─── Crowd Levels (time-series) ──────────────────────
model CrowdLevel {
  id        String   @id @default(cuid())
  venueId   String   @map("venue_id")
  level     Int      // 1=chill, 2=moderate, 3=busy, 4=packed
  label     String   // "Chill", "Active", "Busy", "Packed"
  waitMins  Int?     @map("wait_mins")
  source    String   @default("manual") // "manual", "sensor", "user_report"
  recordedAt DateTime @default(now()) @map("recorded_at")

  venue     Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId, recordedAt(sort: Desc)])
  @@map("crowd_levels")
}

// ─── Parking ─────────────────────────────────────────
model ParkingSpot {
  id          String   @id @default(cuid())
  venueId     String   @map("venue_id")
  name        String   // "Lot A", "Street — 10th St"
  type        String   // "lot", "garage", "street"
  totalSpots  Int      @map("total_spots")
  available   Int
  pricePerHr  Float?   @map("price_per_hr")
  updatedAt   DateTime @updatedAt @map("updated_at")

  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([venueId])
  @@map("parking_spots")
}

// ─── Provider Profiles ───────────────────────────────
model HostProfile {
  id             String    @id @default(cuid())
  userId         String    @unique @map("user_id")
  status         String    @default("draft") // draft | pending | approved | rejected
  currentStep    Int       @default(1) @map("current_step")
  onboardingData Json?     @map("onboarding_data")
  submittedAt    DateTime? @map("submitted_at")
  approvedAt     DateTime? @map("approved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("host_profiles")
}

model ValetProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique @map("user_id")
  status              String    @default("draft") // draft | active | inactive | suspended
  agreementAcceptedAt DateTime? @map("agreement_accepted_at")
  profileData         Json?     @map("profile_data")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("valet_profiles")
}

// ─── Beta Waitlist Leads ─────────────────────────────
// Pre-registration email capture from bytspot.com funnel.
// Separate from User so it works before someone creates a password.
model BetaLead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?                       // first name — for personalised welcome email
  source    String?                       // "bytspot.com", "qr", "tiktok", "organic"
  createdAt DateTime @default(now()) @map("created_at")

  @@map("beta_leads")
}

// ─── Check-In History (per-user) ──────────────────────
model CheckIn {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  venueId       String   @map("venue_id")
  crowdLevel    Int      @map("crowd_level")
  crowdLabel    String   @map("crowd_label")
  pointsEarned  Int      @default(10) @map("points_earned")
  createdAt     DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([venueId])
  @@map("check_ins")
}

// ─── Saved Spots ──────────────────────────────────────
model SavedSpot {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  notes     String?
  tags      String[] @default([])
  savedAt   DateTime @default(now()) @map("saved_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  items SpotCollectionItem[]

  @@unique([userId, venueId])
  @@index([userId])
  @@map("saved_spots")
}

// ─── Spot Collections ─────────────────────────────────
model SpotCollection {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")

  user  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SpotCollectionItem[]

  @@index([userId])
  @@map("spot_collections")
}

model SpotCollectionItem {
  id           String @id @default(cuid())
  collectionId String @map("collection_id")
  savedSpotId  String @map("saved_spot_id")

  collection SpotCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  savedSpot  SavedSpot      @relation(fields: [savedSpotId], references: [id], onDelete: Cascade)

  @@unique([collectionId, savedSpotId])
  @@map("spot_collection_items")
}

// ─── Points Ledger ────────────────────────────────────
model PointTransaction {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  type                  String   // "earn", "spend", "bonus", "SUBSCRIPTION_CREDIT", "MARKETPLACE_CREDIT", "MARKETPLACE_CREDIT_REVERSAL"
  amount                Int
  description           String
  category              String   // "checkin", "achievement", "referral", "review", "streak", "subscription"
  entity                Entity   @default(BYTSPOT_INC)
  stripeSessionId       String?  @unique @map("stripe_session_id")
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  stripeRefundId        String?  @unique @map("stripe_refund_id")
  stripeDisputeId       String?  @unique @map("stripe_dispute_id")
  createdAt             DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@index([entity, category, createdAt(sort: Desc)])
  @@map("point_transactions")
}

// ─── Achievements ─────────────────────────────────────
model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id") // e.g. "first_checkin", "night_owl_10"
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

// ─── User Preferences ─────────────────────────────────
model UserPreference {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  interests String[] @default([])
  vibes     String[] @default([])
  cuisines  String[] @default([])
  parking   Json?    // { covered, evCharging, security }
  behavior  Json?    // { categoryClicks, lastLocations, visitCounts }
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─── Social: Follow Graph ─────────────────────────────
model Follow {
  id          String   @id @default(cuid())
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ─── Reviews ─────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  venueId   String   @map("venue_id")
  stars     Int      // 1-5
  vibe      Int      // 1-10
  comment   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([venueId, createdAt(sort: Desc)])
  @@map("reviews")
}


// ─── Tips (Valet Tipping) ─────────────────────────────
model Tip {
  id                    String   @id @default(cuid())
  fromUserId            String   @map("from_user_id")
  toValetId             String   @map("to_valet_id")
  amount                Float
  stripePaymentIntentId String   @unique @map("stripe_payment_intent_id")
  createdAt             DateTime @default(now()) @map("created_at")

  fromUser User @relation("tipFrom", fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toValetId])
  @@map("tips")
}

// ─── Corporate Entities (multi-tenancy discriminator) ────
// Locked per the Bytspot corporate structure. Rows tagged with the
// subsidiary that owns them for intercompany accounting and audit.
enum Entity {
  BYTSPOT_HOLDINGS
  BYTSPOT_INC
  VENDOR_SERVICES
  EXPERIENCES
  PROPERTY_REIT
  FOUNDATION
}

// ─── Hardware Patches (NTAG424 DNA physical tags) ────────
// Each row represents one physical NFC tag. SDM/SUN keys are stored
// as opaque KMS references — never raw AES material at rest.
model HardwarePatch {
  id            String   @id @default(cuid())
  uid           String   @unique                  // 7-byte NTAG UID (hex)
  tagType       String   @default("NTAG424_DNA") @map("tag_type")
  sdmKeyRef     String?  @map("sdm_key_ref")      // GCP KMS key reference
  readCounter   Int      @default(0) @map("read_counter") // last observed SDM counter
  label         String?
  status        String   @default("unbound")      // unbound | bound | retired
  entity        Entity   @default(BYTSPOT_INC)
  bindingType   String?  @map("binding_type")     // "vendor" | "service" | "venue"
  bindingId     String?  @map("binding_id")
  confirmedAt   DateTime? @map("confirmed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  services      VendorService[]

  @@index([status])
  @@index([bindingType, bindingId])
  @@map("hardware_patches")
}

// ─── Vendors (cottage industry / VIP service providers) ──
model Vendor {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  entity            Entity   @default(VENDOR_SERVICES)
  displayName       String   @map("display_name")
  legalName         String?  @map("legal_name")
  stripeAccountId   String?  @unique @map("stripe_account_id")
  onboardingStatus  String   @default("pending") @map("onboarding_status") // pending | active | suspended
  commissionBps     Int      @default(800) @map("commission_bps")          // 800 = 8%
  metadata          Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  services VendorService[]
  bookings Booking[]

  @@index([userId])
  @@index([entity])
  @@map("vendors")
}

// ─── Vendor Services (bookable products / appointments) ──
model VendorService {
  id           String   @id @default(cuid())
  vendorId     String   @map("vendor_id")
  title        String
  description  String?
  priceCents   Int      @map("price_cents")
  currency     String   @default("USD")
  durationMins Int?     @map("duration_mins")
  status       String   @default("draft") // draft | active | archived
  patchId      String?  @map("patch_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor   Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  patch    HardwarePatch? @relation(fields: [patchId], references: [id], onDelete: SetNull)
  bookings Booking[]

  @@index([vendorId, status])
  @@index([patchId])
  @@map("vendor_services")
}

// ─── Bookings (completed purchases / reservations) ───────
model Booking {
  id                    String    @id @default(cuid())
  serviceId             String    @map("service_id")
  vendorId              String    @map("vendor_id")
  userId                String    @map("user_id")
  entity                Entity    @default(VENDOR_SERVICES)
  status                String    @default("pending") // pending | paid | confirmed | completed | canceled | refunded | disputed
  priceCents            Int       @map("price_cents")
  platformFeeCents      Int       @default(0) @map("platform_fee_cents")
  currency              String    @default("USD")
  stripeSessionId       String?   @unique @map("stripe_session_id")
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id")
  stripeTransferDestination String? @map("stripe_transfer_destination")
  ictJti                String?   @unique @map("ict_jti")  // JWT ID of the signed Immutable Compliance Token
  scheduledFor          DateTime? @map("scheduled_for")
  completedAt           DateTime? @map("completed_at")
  metadata              Json?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  service VendorService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  vendor  Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([vendorId, status])
  @@index([serviceId])
  @@index([entity, status])
  @@map("bookings")
}

// ─── Liability Vault Records (WORM audit trail) ──────────
// Authoritative evidence is GCS Object Lock; IPFS CID is a public
// cryptographic manifest of the sha256 for tamper-evidence.
model LiabilityRecord {
  id             String    @id @default(cuid())
  resourceType   String    @map("resource_type")   // "booking" | "tap" | "vendor" | ...
  resourceId     String    @map("resource_id")
  sha256         String    @unique                  // hex-encoded content hash
  gcsObjectPath  String?   @map("gcs_object_path")  // gs://bucket/path
  gcsGeneration  BigInt?   @map("gcs_generation")
  ipfsCid        String?   @map("ipfs_cid")
  lockedUntil    DateTime? @map("locked_until")
  entity         Entity    @default(BYTSPOT_INC)
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([resourceType, resourceId])
  @@index([entity, createdAt(sort: Desc)])
  @@map("liability_records")
}

// ─── Compliance Logs (Sovereign Shield audit trail) ──────
model ComplianceLog {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  entity         Entity   @default(BYTSPOT_INC)
  procedure      String                                   // tRPC path, e.g. "patch.verifyTap"
  frameworks     String[] @default([])                    // ["NIST_AI_RMF_1_0", "EO_14365"]
  policyContext  Json?    @map("policy_context")
  stateFlags     String[] @default([]) @map("state_flags") // ["GA_BH1", "CA_SB53"]
  outcome        String   @default("allow")                // allow | deny | flag
  reason         String?
  requestIp      String?  @map("request_ip")
  createdAt      DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([procedure, createdAt(sort: Desc)])
  @@index([entity, createdAt(sort: Desc)])
  @@map("compliance_logs")
}

// ─── Audit Log (NIST PR.PT-1) ────────────────────────────
// Append-only record of patch verification attempts. Matches the
// VirtualPatchAuditEvent shape emitted by the client audit sink.
model AuditLog {
  id        String   @id @default(cuid())
  at        DateTime                                     // event timestamp from client
  outcome   String                                       // success | failure | revoked | consent_denied
  method    String                                       // scan method (nfc | qr | ...)
  vendorId  String?  @map("vendor_id")
  patchId   String?  @map("patch_id")
  uid       String?
  tokenJti  String?  @map("token_jti")
  venueId   String?  @map("venue_id")
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")  // server receive time

  @@index([vendorId, at(sort: Desc)])
  @@index([patchId, at(sort: Desc)])
  @@index([outcome, at(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── Revoked Patches (NIST RS.MI-1) ──────────────────────
// Source of truth for the client revocation cache. A row here means the
// patchId is blocked from successful verification regardless of token state.
model RevokedPatch {
  id        String   @id @default(cuid())
  patchId   String   @map("patch_id")
  vendorId  String?  @map("vendor_id")                   // null = platform-wide revocation
  reason    String?
  revokedBy String?  @map("revoked_by")                  // operator userId
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([patchId, vendorId])
  @@index([vendorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("revoked_patches")
}
