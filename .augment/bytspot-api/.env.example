# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bytspot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"

# CORS — comma-separated allowed origins
CORS_ORIGINS="http://localhost:3000,https://bytspot.com"
